{
  "name": "crm-automation",
  "version": "1.0.0",
  "description": "Playwright TypeScript BDD automation framework for CRM Admin - Products Module",
  "scripts": {
    "test": "rimraf allure-results && playwright test",
    "test:smoke": "rimraf allure-results && playwright test --grep @smoke",
    "test:regression": "rimraf allure-results && playwright test --grep @regression",
    "test:products": "rimraf allure-results && playwright test tests/spec/products/",
    "test:auth": "rimraf allure-results && playwright test tests/spec/auth/",
    "test:network": "playwright test --grep @network",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "cucumber": "rimraf allure-results && cucumber-js",
    "cucumber:smoke": "rimraf allure-results && cucumber-js --tags @smoke",
    "cucumber:regression": "rimraf allure-results && cucumber-js --tags @regression",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "report": "playwright show-report",
    "clean": "rimraf allure-results allure-report test-results playwright-report"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "winston": "^3.13.0",
    "openai": "^4.52.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.13.0",
    "@cucumber/cucumber": "^10.8.0",
    "@cucumber/html-formatter": "^21.3.0",
    "allure-playwright": "^3.0.0",
    "allure-commandline": "^2.30.0",
    "rimraf": "^5.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}